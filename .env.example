WORKATO_API_TOKEN=your-developer-api-token-here
WORKATO_API_BASE_URL=https://www.workato.com/api

# HTTP server only (Railway / Render / Docker)
MCP_API_KEY=generate-a-long-random-secret-here
PORT=8080

# Optional: comma-separated hostnames for DNS rebinding protection (e.g. your-app.up.railway.app)
# ALLOWED_HOSTS=workato-mcp-production.up.railway.app

# Required only for npx @gemunah-cyber/workato-mcp (private GitHub Packages) — stdio/cloud Command path
NODE_AUTH_TOKEN=ghp_your-github-pat-read-packages
